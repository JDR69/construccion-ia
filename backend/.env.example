
### PostgreSQL
POSTGRES_DB=construccionia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres ## escriben su contraseña de su pgadmin
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

### Gemini
GEMINI_API_KEY=TU_API_KEY_AQUI
# Opcional: fuerza el modelo (si no se define, el backend elige uno compatible automáticamente)
# Ejemplos (según disponibilidad de tu API key):
# GEMINI_MODEL=models/gemini-2.0-flash
# GEMINI_MODEL=models/gemini-2.5-flash
