
### PostgreSQL
POSTGRES_DB=construccionia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres ## escriben su contraseña de su pgadmin
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

### Gemini
GEMINI_API_KEY=TU_API_KEY_AQUI
# Opcional: fuerza el modelo (si no se define, el backend elige uno compatible automáticamente)
# Ejemplos (según disponibilidad de tu API key):
# GEMINI_MODEL=models/gemini-2.0-flash
# GEMINI_MODEL=models/gemini-2.5-flash

# Opcional: separar modelo rápido vs modelo fuerte (el backend reintenta 1 vez con el fuerte
# si el rápido no detecta geometría o devuelve JSON inválido)
# GEMINI_MODEL_FAST=models/gemini-2.5-flash
# GEMINI_MODEL_STRONG=models/gemini-2.5-pro

### OpenAI (Vision)
# IA_PROVIDER=openai
# OPENAI_API_KEY=TU_API_KEY_AQUI
# Modelo para vision: gpt-4o (soporta imagenes), gpt-4o-mini, gpt-4-turbo
# NOTA: gpt-4o-mini NO soporta vision/imagenes en el API de chat completions
# OPENAI_MODEL=gpt-4o
# Modelo para chatbot de edicion de planos (texto)
# OPENAI_CHAT_MODEL=gpt-4.1
